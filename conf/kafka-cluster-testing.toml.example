# =====================================================================
# Kafka Cluster Testing Tool - Example Configuration
#
# Before running the tool, verify that `security_protocol` and
# `auth.mode` are consistent with each other.
#
# ---------------------------------------------------------------------
# MODE 1: CLUSTER WITHOUT KERBEROS (PLAINTEXT / no SASL)
# ---------------------------------------------------------------------
# Use this mode for a plain Kafka listener without SASL authentication.
#
# Required settings:
#   [kafka]
#   security_protocol = "PLAINTEXT"
#
#   [auth]
#   mode = "none"
#
# Result:
#   - checks cluster reachability
#   - creates, writes, and reads test topics
#   - does not use Kerberos or JAAS
#
# ---------------------------------------------------------------------
# MODE 2: CLUSTER WITH KERBEROS (SASL_PLAINTEXT or SASL_SSL)
# ---------------------------------------------------------------------
# Use this mode for a secured Kafka cluster.
#
# Required settings:
#   [kafka]
#   security_protocol = "SASL_PLAINTEXT"  # or SASL_SSL
#
#   [auth]
#   mode = "auto"       # recommended
#   # or
#   mode = "kerberos"   # strict mode
#
#   [auth.kerberos]
#   krb5_conf = "/etc/krb5.conf"
#   principal = "kafka/client01.example.com@EXAMPLE.COM"
#   keytab = "/etc/security/keytabs/kafka-client.keytab"
#
# Result:
#   - verifies Kerberos authentication
#   - surfaces ACL / authorization issues as DENY
#
# ---------------------------------------------------------------------
# IMPORTANT
# ---------------------------------------------------------------------
# INVALID CONFIGURATION:
#   security_protocol = "SASL_*"
#   auth.mode = "none"
#
# Kafka clients cannot use SASL without JAAS/Kerberos configuration.
# The tool exits with a configuration error in this case.
#
# ---------------------------------------------------------------------
# RECOMMENDATION
# ---------------------------------------------------------------------
# If you are unsure, use:
#   auth.mode = "auto"
#
# The tool will resolve the proper mode and provide clear diagnostics.
# =====================================================================

[app]
dry_run = false
output_dir = "./out"
write_report_json = true
color = "auto"
quiet = false

[kafka]
bootstrap_servers = "kafka01.example.com:9093,kafka02.example.com:9093,kafka03.example.com:9093"
# PLAINTEXT | SSL | SASL_PLAINTEXT | SASL_SSL
security_protocol = "SASL_PLAINTEXT"
client_id = "kafka-cluster-testing"

# TLS (for SSL or SASL_SSL)
# ssl_truststore_location = "/etc/security/kafka.client.truststore.jks"
# ssl_truststore_password = "changeit"

[auth]
# auto | none | kerberos
mode = "auto"

[auth.kerberos]
krb5_conf = "/etc/krb5.conf"
principal = "kafka/client01.example.com@EXAMPLE.COM"
keytab = "/etc/security/keytabs/kafka-client.keytab"
sasl_mechanism = "GSSAPI"
sasl_kerberos_service_name = "kafka"

[test]
# Prefix for temporary test topics
topics_prefix = "kct"
topics_count = 3
partitions = 1
replication_factor = 3
messages_per_topic = 5
produce_acks = "all"
consume_timeout_ms = 20000
poll_interval_ms = 250
consumer_group_prefix = "kct"
delete_topics_after = true
wait_topics_ready_timeout_ms = 15000
wait_end_offsets_timeout_ms = 15000
subscribe_assign_timeout_ms = 5000
